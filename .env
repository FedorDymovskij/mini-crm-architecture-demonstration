# Порт сервера
ENV_SERVER_PORT=8080
# Имя пользователя в базе данных
ENV_POSTGRES_USER=test_postgres_user
# Пароль пользователя в базе данных
ENV_POSTGRES_PASSWORD=test_postgres_password
# Название создаваемой базы данных
ENV_POSTGRES_DB=crm_DDD_database
# Внешний порт для базы данных (для подключения к базе данных из вне)
ENV_POSTGRES_EXTERNAL_PORT=3000
# Секретный код для подписи JWT Access токенов
ENV_SECURITY_ACCESS_TOKEN_SECRET_KEY=my-super-amazing-mega-secret-key
# Время жизни JWT Access токена в миллисикундах
ENV_SECURITY_ACCESS_TOKEN_EXPIRATION_MS=120000
