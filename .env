# Порт сервера
ENV_SERVER_PORT=8080
# Имя пользователя в базе данных
ENV_POSTGRES_USER=test-user
# Пароль пользователя в базе данных
ENV_POSTGRES_PASSWORD=test-password
# Название создаваемой базы данных
ENV_POSTGRES_DB=security-demonstration-database
# Внешний порт для базы данных (для подключения к базе данных из вне)
ENV_POSTGRES_EXTERNAL_PORT=5000
# Секретный код для подписи JWT токенов
ENV_JWT_SECRET_KEY=my-super-amazing-mega-secret-key
# Время жизни JWT Access токена в миллисикундах
ENV_JWT_EXPIRATION_MS=120000
# Время жизни Refresh токена в базе данных в миллисикундах
ENV_REFRESH_TOKEN_EXPIRATION_MS=300000